# URL du backend NestJS (avec le préfixe /api)
VITE_API_URL=

# Origine du backend pour les connexions WebSocket (Socket.IO)
VITE_BACKEND_ORIGIN=

# Simulation de paiement (démo/local sans NovaSend réel).
# Vide = actif en dev, inactif en prod. Mettre 'true' pour forcer, 'false' pour désactiver.
VITE_SIMULATE_PAYMENT=
